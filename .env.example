# ============================================================
#  Planificateur de bénévoles — Festival
#  Fichier de configuration d'environnement
#
#  USAGE :
#    1. Copier ce fichier : cp .env.example .env
#    2. Remplir les valeurs ci-dessous
#    3. Ne JAMAIS commiter le fichier .env (voir .gitignore)
# ============================================================

# ── Base de données MySQL / MariaDB ──────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=

# ── Application ──────────────────────────────────────────────
APP_NAME="Planificateur de bénévoles"
APP_URL=http://localhost
APP_ENV=development
# APP_ENV=production

# ── Sécurité session ─────────────────────────────────────────
# Générer une clé aléatoire : php -r "echo bin2hex(random_bytes(32));"
SESSION_SECRET=change_me_with_a_random_secret_key

# ── Timezone ─────────────────────────────────────────────────
APP_TIMEZONE=Europe/Paris